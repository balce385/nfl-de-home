# Kopiere zu .env.deploy und trage echte Werte ein.
# WICHTIG: .env.deploy gehört in .gitignore — niemals committen!

# --- Vercel ---
VERCEL_TOKEN=
# Optional, sonst initialisiert das Script per `vercel pull`/`vercel link`
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Railway ---
RAILWAY_TOKEN=
RAILWAY_BACKEND_SERVICE=backend
RAILWAY_REALTIME_SERVICE=realtime

# --- Supabase ---
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# --- Wird in Vercel als Production-Env gesetzt (optional, aber empfohlen) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SITE_URL=
